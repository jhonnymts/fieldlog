{
  "name": "DailyLog",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Reference to the project"
    },
    "log_date": {
      "type": "string",
      "format": "date",
      "description": "Date of the log"
    },
    "executive_summary": {
      "type": "string",
      "description": "End-of-day executive summary"
    },
    "lookahead": {
      "type": "string",
      "description": "Lookahead notes for upcoming work"
    }
  },
  "required": [
    "project_id",
    "log_date"
  ]
}