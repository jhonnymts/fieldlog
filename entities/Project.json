{
  "name": "Project",
  "type": "object",
  "properties": {
    "project_name": {
      "type": "string",
      "description": "Name of the project"
    },
    "client_name": {
      "type": "string",
      "description": "Client company name"
    },
    "location": {
      "type": "string",
      "description": "Project location"
    },
    "project_number": {
      "type": "string",
      "description": "Project number/code"
    },
    "activity_type": {
      "type": "string",
      "enum": [
        "FAT",
        "SAT",
        "T&C",
        "Commissioning"
      ],
      "description": "Type of activity"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Project start date"
    }
  },
  "required": [
    "project_name",
    "activity_type"
  ]
}